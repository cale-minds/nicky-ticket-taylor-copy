{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_BASE_URL": "https://nicky-ticket-taylor.vercel.app",
    "API_BASE_PATH": "/api",
    "ADMIN_API_BASE_PATH": "/api",
    "AUTH0_CALLBACK_PATH": "/admin-ui/callback"
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/admin-ui(?:/.*)?$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/overview/?$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/authentication/login-callback$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/api(?:/.*)?$",
      "dest": "/api/index.py"
    }
  ]
}
