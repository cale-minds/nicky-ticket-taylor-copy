# Runtime
APP_ENV=development
APP_BASE_URL=http://localhost:8017
DATABASE_PATH=./data/integration.sqlite3
DEFAULT_TENANT_ID=default
DRY_RUN=true
LOG_LEVEL=INFO

# Ticket Tailor bootstrap for DEFAULT_TENANT_ID
TICKET_TAILOR_API_BASE_URL=https://api.tickettailor.com
TICKET_TAILOR_API_KEY=
TICKET_TAILOR_WEBHOOK_SIGNING_SECRET=
TICKET_TAILOR_WEBHOOK_TOLERANCE_SECONDS=300
TICKET_TAILOR_OFFLINE_PAYMENT_KEYWORDS=nicky,nicky payment
TICKET_TAILOR_PENDING_TICKET_EXPIRATION_HOURS=0
TICKET_TAILOR_EXPIRATION_CHECK_INTERVAL_SECONDS=300
TICKET_TAILOR_EXPIRATION_BATCH_SIZE=100
AUTO_CONFIRM_TICKET_TAILOR_PAYMENTS=false

# Nicky bootstrap for DEFAULT_TENANT_ID
NICKY_API_BASE_URL=https://api-public.pay.nicky.me
NICKY_PAY_BASE_URL=https://pay.nicky.me
NICKY_API_KEY=
NICKY_DEFAULT_BLOCKCHAIN_ASSET_ID=
NICKY_RECEIVER_SHORT_ID=
AUTO_CREATE_NICKY_PAYMENT_REQUEST=true
NICKY_SEND_NOTIFICATION=true
NICKY_SUCCESS_URL=
NICKY_CANCEL_URL=
NICKY_WEBHOOK_TYPE=2
SKIP_NICKY=false

# Nicky OpenAPI does not advertise a webhook signature scheme.
# Use this as a shared token in the webhook URL query string or X-Nicky-Webhook-Token header.
NICKY_WEBHOOK_TOKEN=

# Optional protection for manual/admin endpoints.
ADMIN_TOKEN=
