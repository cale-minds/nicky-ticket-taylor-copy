# Runtime
APP_ENV=development
APP_BASE_URL=http://localhost:8017
API_BASE_PATH=/api
ADMIN_API_BASE_PATH=/api
# Prefer DATABASE_URL for deploys. DATABASE_PATH is the local SQLite fallback.
DATABASE_URL=
DATABASE_PATH=./data/integration.sqlite3
LOG_LEVEL=INFO
RUN_BACKGROUND_JOBS=false
JOB_RUNNER_TOKEN=
CRON_SECRET=

# Ticket Tailor
TICKET_TAILOR_WEBHOOK_TOLERANCE_SECONDS=300
TICKET_TAILOR_PENDING_TICKET_EXPIRATION_HOURS=0
TICKET_TAILOR_EXPIRATION_CHECK_INTERVAL_SECONDS=300
TICKET_TAILOR_EXPIRATION_BATCH_SIZE=100

# Nicky
NICKY_API_BASE_URL=https://api-public.pay.nicky.me
NICKY_PAY_BASE_URL=https://pay.nicky.me
NICKY_SUCCESS_URL=
NICKY_CANCEL_URL=

# Required Auth0 protection for /admin-ui and admin APIs.
# Users authenticate with Auth0.
# Roles in ADMIN_ALLOWED_ROLES are admins; role Support is read-only; users without these roles are common users.
ADMIN_SESSION_SECRET=change-this-in-production
ADMIN_SESSION_MAX_AGE_SECONDS=28800
# Temporary diagnostic flag. Never leave this enabled in production longer than needed.
DEBUG_AUTH0_ERRORS=true
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
# Optional. Leave empty for a public Auth0 client; PKCE will be used.
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
# Use /overview only for the local localhost:4200 Angular compatibility test.
AUTH0_CALLBACK_PATH=/admin-ui/callback
ADMIN_ALLOWED_ROLES=Admin
